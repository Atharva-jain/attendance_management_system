<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/auth_nav"
    app:startDestination="@id/splashScreenFragment">

    <fragment
        android:id="@+id/chooseOptionLoginFragment"
        android:name="com.yeloe.attentanceapp.ui.fragment.authentication.ChooseOptionLoginFragment"
        android:label="fragment_choose_option_login"
        tools:layout="@layout/fragment_choose_option_login" >
        <action
            android:id="@+id/action_chooseOptionLoginFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.yeloe.attentanceapp.ui.fragment.authentication.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_createAccountFragment"
            app:destination="@id/createAccountFragment" />
        <argument
            android:name="type"
            app:argType="string" />
        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordDialogFragment"
            app:destination="@id/forgotPasswordDialogFragment" />

    </fragment>
    <fragment
        android:id="@+id/createAccountFragment"
        android:name="com.yeloe.attentanceapp.ui.fragment.authentication.CreateAccountFragment"
        android:label="fragment_create_account"
        tools:layout="@layout/fragment_create_account" >
        <argument
            android:name="type"
            app:argType="string" />
        <action
            android:id="@+id/action_createAccountFragment_to_signUpBasicDetailsFromFragment"
            app:destination="@id/signUpBasicDetailsFromFragment" />
        <action
            android:id="@+id/action_createAccountFragment_to_loginFragment3"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <dialog
        android:id="@+id/forgotPasswordDialogFragment"
        android:name="com.yeloe.attentanceapp.ui.fragment.authentication.ForgotPasswordDialogFragment"
        android:label="fragment_forgot_password_dialog"
        tools:layout="@layout/fragment_forgot_password_dialog" />
    <fragment
        android:id="@+id/signUpBasicDetailsFromFragment"
        android:name="com.yeloe.attentanceapp.ui.fragment.authentication.SignUpBasicDetailsFromFragment"
        android:label="fragment_sign_up_basic_details_from"
        tools:layout="@layout/fragment_sign_up_basic_details_from" >
        <argument
            android:name="type"
            app:argType="string" />
        <action
            android:id="@+id/action_signUpBasicDetailsFromFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/signUpBasicDetailsFromFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/splashScreenFragment"
        android:name="com.yeloe.attentanceapp.ui.fragment.SplashScreenFragment"
        android:label="fragment_splash_screen"
        tools:layout="@layout/fragment_splash_screen" >
        <action
            android:id="@+id/action_splashScreenFragment_to_chooseOptionLoginFragment"
            app:destination="@id/chooseOptionLoginFragment"
            app:popUpTo="@id/splashScreenFragment"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>