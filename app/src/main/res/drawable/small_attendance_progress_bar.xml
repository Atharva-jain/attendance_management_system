<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer background -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_12sdp" /> <!-- Larger radius for outer background -->
            <solid android:color="?colorPrimaryInverse" />
        </shape>
    </item>
    <!-- Inner progress -->
    <item android:id="@android:id/progress">
        <scale android:scaleWidth="100%">
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/_12sdp" /> <!-- Larger radius for outer background -->
                <solid android:color="?colorSurfaceInverse" />
                <!-- Adjust the height of the progress bar here -->
                <size android:height="@dimen/_12sdp" />
            </shape>
        </scale>
    </item>
    <!-- Message text -->
    <item android:id="@android:id/message">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/_12sdp" /> <!-- Larger radius for outer background -->
            <solid android:color="@android:color/transparent" /> <!-- Transparent background -->
            <!-- Adjust the height of the message text here if needed -->
            <size android:height="@dimen/_12sdp" />
        </shape>
    </item>
</layer-list>
